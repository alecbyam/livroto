{
  "name": "livroto-desktop",
  "version": "1.0.0",
  "description": "Livroto — Marketplace de Bunia (app desktop)",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "author": {
    "name": "Livroto Bunia",
    "email": "contact@livroto.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0"
  },
  "build": {
    "appId": "com.livroto.bunia",
    "productName": "Livroto",
    "copyright": "Copyright © 2026 Livroto Bunia",
    "icon": "../public/icon-512.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "!node_modules/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "../public/icon-512.png",
      "publisherName": "Livroto Bunia"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Livroto"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "../public/icon-512.png",
      "category": "public.app-category.shopping",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] },
        { "target": "rpm", "arch": ["x64"] }
      ],
      "icon": "../public/icon-512.png",
      "category": "Network",
      "desktop": {
        "Name": "Livroto",
        "Comment": "Marketplace de Bunia — commande et livraison locale"
      }
    },
    "publish": {
      "provider": "github",
      "owner": "alecbyam",
      "repo": "livroto"
    }
  }
}
